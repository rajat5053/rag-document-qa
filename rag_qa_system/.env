# ─────────────────────────────────────────────────────────────
# RAG Document Q&A System — Environment Variables
# ─────────────────────────────────────────────────────────────
# Fill in your values, then save.
# Never commit this file to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM: NVIDIA NIM API (required) ───────────────────────────
# Get your key at: https://build.nvidia.com  → top-right "Get API Key"
NVIDIA_API_KEY=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

# ── Embeddings: local model path (required) ───────────────────
# Full path to your locally saved BAAI/bge-large-en-v1.5 folder.
# Example (Windows):  C:\Users\You\models\bge-large-en-v1.5
# Example (Linux):    /home/you/models/bge-large-en-v1.5
EMBEDDING_MODEL_PATH=D:\BGE_Large

# Embedding inference device: cpu (default) or cuda
# Use "cpu" unless you have confirmed your PyTorch CUDA build matches your GPU.
# Check with: python -c "import torch; print(torch.version.cuda)"
EMBEDDING_DEVICE=cpu

# ── FastAPI backend URL (optional) ────────────────────────────
# Used by the Streamlit frontend. Change only if backend is remote.
FASTAPI_URL=http://127.0.0.1:8000
