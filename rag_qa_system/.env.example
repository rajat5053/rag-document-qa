# ─────────────────────────────────────────────────────────────
# RAG Document Q&A System — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` in the same directory and fill in your values.
# NEVER commit the actual `.env` file to your git repository.
# ─────────────────────────────────────────────────────────────

# ── LLM: NVIDIA NIM API (Required) ───────────────────────────
# Generate your API Key at: https://build.nvidia.com (NVIDIA API Catalog)
# The key should start with "nvapi-"
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Embeddings: Local Model Path (Required) ──────────────────
# Full absolute path to your locally downloaded BAAI/bge-large-en-v1.5 directory.
# This folder must contain: config.json, pytorch_model.bin, tokenizer.json, etc.
# Examples:
#   Windows: C:\Users\YourName\models\bge-large-en-v1.5
#   Linux:   /home/yourname/models/bge-large-en-v1.5
EMBEDDING_MODEL_PATH=C:\path\to\your\bge-large-en-v1.5

# ── Embedding Inference Device (Optional) ────────────────────
# Set to "cpu" (default) or "cuda" (if GPU-enabled PyTorch is configured).
# Use "cpu" if you see 'cudaErrorNoKernelImageForDevice' errors.
EMBEDDING_DEVICE=cpu

# ── FastAPI Backend URL (Optional) ───────────────────────────
# Used by the Streamlit frontend to communicate with the API.
# Change this only if you run the backend on a remote host.
FASTAPI_URL=http://127.0.0.1:8000
